  <path android:fillColor="#0F1117"
        android:pathData="M50,80 L58,80 L58,90 L50,90 Z"/>
  <path android:fillColor="#0F1117"
        android:pathData="M18,50 L28,50 L28,58 L18,58 Z"/>
  <path android:fillColor="#0F1117"
        android:pathData="M80,50 L90,50 L90,58 L80,58 Z"/>

