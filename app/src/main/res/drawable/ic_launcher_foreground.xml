<?xml version="1.0" encoding="utf-8"?>
<!--
  Civil Suite – Adaptive Icon Foreground
  Full-bleed amber fill so MIUI/stock launcher clips it to a rounded square.
  Design: Construction hard hat + I-beam, navy on amber.
  Safe zone = inner 72dp (18dp margin each side on the 108dp canvas).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Full-bleed amber fill – launcher clips this to rounded rect -->
    <path
        android:fillColor="#E8AB00"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"/>

    <!-- Hard hat dome (navy) – centred in safe zone -->
    <path
        android:fillColor="#1A1C24"
        android:pathData="M30,62
            C30,44 39,34 54,33
            C69,34 78,44 78,62
            Z"/>

    <!-- Hat brim (navy) -->
    <path
        android:fillColor="#1A1C24"
        android:pathData="M26,62 L82,62 L82,68 Q54,72 26,68 Z"/>

    <!-- Yellow centre stripe on dome -->
    <path
        android:fillColor="#E8AB00"
        android:pathData="M51,33.5 L51,62 L57,62 L57,33.5 Q54,33 51,33.5 Z"/>

    <!-- I-beam below hat (navy) -->
    <!-- Top flange -->
    <path
        android:fillColor="#1A1C24"
        android:pathData="M36,76 L72,76 L72,81 L36,81 Z"/>
    <!-- Web -->
    <path
        android:fillColor="#1A1C24"
        android:pathData="M50,81 L58,81 L58,91 L50,91 Z"/>
    <!-- Bottom flange -->
    <path
        android:fillColor="#1A1C24"
        android:pathData="M36,91 L72,91 L72,96 L36,96 Z"/>

</vector>
